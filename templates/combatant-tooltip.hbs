<div class="combat-dock-tooltip-wrapper">
    <div class="portrait-header">
        <h2>{{name}}</h2>
        <div class="initiative" {{#if isInitiativeNaN}}style="display:none;"{{/if}}>

            <i {{#if initiativeData.isIconImg}}style="background-image: url('{{initiativeData.icon}}');"{{else}}class="{{initiativeData.icon}}"{{/if}}></i>        
            <h3>{{initiativeData.value}}</h3>
        </div>
    </div>
    {{#if hasPermission}}
    {{#if description}}
    <p>{{ description}}</p>
    {{/if}}
    {{/if}}
    {{#if isDaggerheart}}
    <div class="daggerheart-tooltip-summary">
        <div class="daggerheart-tooltip-row">
            <span>{{localize "combat-tracker-dock.tooltip.daggerheart.spotlight"}}</span>
            <strong>
                {{#if active}}
                {{localize "combat-tracker-dock.tooltip.daggerheart.stateActive"}}
                {{else if dhIsRequesting}}
                {{localize "combat-tracker-dock.tooltip.daggerheart.stateRequest" order=dhRequestOrder}}
                {{else}}
                {{localize "combat-tracker-dock.tooltip.daggerheart.stateIdle"}}
                {{/if}}
            </strong>
        </div>
        {{#if defeated}}
        <div class="daggerheart-tooltip-row">
            <span>{{localize "combat-tracker-dock.tooltip.daggerheart.status"}}</span>
            <strong>{{localize "combat-tracker-dock.tooltip.daggerheart.defeated"}}</strong>
        </div>
        {{/if}}
        {{#if hasPermission}}
        {{#if dhShowTooltipActionTokens}}
        <div class="daggerheart-tooltip-row">
            <span>{{localize "combat-tracker-dock.tooltip.daggerheart.actionTokens"}}</span>
            <strong>{{dhActionTokensCurrent}}/{{dhActionTokensMax}}</strong>
        </div>
        {{/if}}
        {{#if dhHasPrimaryResource}}
        <div class="daggerheart-tooltip-row">
            <span>{{localize "combat-tracker-dock.tooltip.daggerheart.hitPoints"}}</span>
            <strong>{{resource.value}}{{#if resource.max}}/{{resource.max}}{{/if}}</strong>
        </div>
        {{/if}}
        {{#if dhHasSecondaryResource}}
        <div class="daggerheart-tooltip-row">
            <span>{{localize "combat-tracker-dock.tooltip.daggerheart.stress"}}</span>
            <strong>{{resource2.value}}{{#if resource2.max}}/{{resource2.max}}{{/if}}</strong>
        </div>
        {{/if}}
        {{#if dhHasEvasion}}
        <div class="daggerheart-tooltip-row">
            <span>{{localize "combat-tracker-dock.tooltip.daggerheart.evasion"}}</span>
            <strong>{{dhEvasion}}</strong>
        </div>
        {{/if}}
        {{/if}}
    </div>
    {{/if}}
    {{#if hasPermission}}
    {{#unless isDaggerheart}}
    <ul {{#unless hasAttributes}}style="display:none;" {{/unless}}>
        {{#each attributes as |attribute|}}
        <li>{{{attribute.icon}}}<span>{{#if
                attribute.max}}{{attribute.value}}/{{attribute.max}}{{else}}{{{attribute.value}}}{{/if}}
                <i>{{attribute.units}}</i></span>
        </li>
        {{/each}}
    </ul>
    {{/unless}}
    {{/if}}
    <ul {{#unless hasEffects}}style="display:none;" {{/unless}}>
        {{#each effects as |effect|}}
        <li class="effects-list">
            <div class="percent-border" style="background: conic-gradient(var(--carousel-tooltip-color) {{percent}}%, var(--carousel-tooltip-bg-color) 0);"></div>
            <img src="{{effect.img}}" alt=""><span>{{{localize effect.label}}}</span>{{#if hasDuration}}{{#if ../hasPermission}}<span class="tooltip-duration"><i class="fa-duotone fa-stopwatch"></i> {{duration}}</span>{{/if}}{{/if}}</li>
        {{#if effect.description}}
        {{#if ../displayDescriptions}}
            <div class="effect-description">{{{effect.description}}}</div>
        {{/if}}
        {{/if}}
        {{/each}}
    </ul>

    {{#if tooltipSystemIcons}}
        <div class="system-icons">
            {{#each resSystemIcons}}
            <i class="system-icon {{icon}}" style="color: {{color}};{{#unless visible}}display: none;{{/unless}}{{#unless enabled}}filter: grayscale(1);{{/unless}}{{#if fontSize}}font-size: {{fontSize}};{{/if}}"></i>
            {{/each}}
        </div>
    {{/if}}

</div>
