<div class="combatant-wrapper" style="background-image: url('{{img}}');{{#if defeated}}filter: grayscale(1);{{/if}}">

    {{#unless isDaggerheart}}
    {{#if hasPortraitResource}}
    <div class="portrait-bar" style="height: calc( 100% - {{portraitResource.percentage}}% );"></div>
    {{/if}}
    {{/unless}}

    {{#if isDaggerheart}}
    <div class="daggerheart-top-controls">
        {{#if dhCanToggleSpotlight}}
        <button type="button" class="daggerheart-action daggerheart-button" data-action="toggle-spotlight" title="{{localize 'combat-tracker-dock.controls.toggleSpotlight'}}">
            <i class="fa-solid {{#if active}}fa-hand-sparkles{{else}}fa-hand{{/if}}"></i>
        </button>
        {{/if}}

        {{#if dhCanRequestSpotlight}}
        <button type="button" class="daggerheart-action daggerheart-button {{#if dhIsRequesting}}requesting{{/if}}" data-action="request-spotlight" title="{{localize 'combat-tracker-dock.controls.requestSpotlight'}}">
            <i class="fa-solid {{#if dhIsRequesting}}fa-hand-sparkles{{else}}fa-hand{{/if}}"></i>
        </button>
        {{/if}}
    </div>
    {{/if}}



    <div class="overlay-ui-container">
    {{#unless isDaggerheart}}
    {{#if resource.max}}
        <div class="tracked-attribute-bar-max" style="order: {{barsOrder.bar1}};margin-left: {{barsOrder.bar1ML}};{{#unless showBars}}display: none;{{/unless}}" >
        <div class="tracked-attribute-bar-current" style="height: {{resource.percentage}}%;"></div>
        </div>
    {{/if}}
    {{#if resource2.max}}
        <div class="tracked-attribute-bar-max" style="order: {{barsOrder.bar2}};margin-left: {{barsOrder.bar2ML}};{{#unless showBars}}display: none;{{/unless}}">
        <div class="tracked-attribute-bar-current secondary-attribute" style="height: {{resource2.percentage}}%;"></div>
        </div>
    {{/if}}
        <ul class="effects-container" style="order: {{barsOrder.effects}};{{#unless hasEffects}}display:none;{{/unless}}" >
        {{#each effects as |effect|}}
        <li class="portrait-effect" data-uuid="{{effect.uuid}}" style="background-image: url('{{effect.img}}');">
            <div class="percent-border" style="background: conic-gradient(var(--carousel-tooltip-color) {{percent}}%, var(--carousel-tooltip-bg-color) 0);"></div>
        </li>
        {{/each}}
    </ul>
    {{/unless}}
    </div>
    <div class="bottom-ui-container {{#if isDaggerheart}}daggerheart-controls{{/if}}">

        {{#if hasDhActionTokens}}
        <div class="daggerheart-action-tokens">
            {{#each dhActionTokens}}
            <button type="button" class="daggerheart-action action-token {{#if spent}}spent{{/if}}" data-action="set-action-token" data-token-index="{{index}}" title="{{localize 'combat-tracker-dock.controls.actionToken'}}" {{#unless canToggle}}disabled{{/unless}}>
                <i class="fa-solid fa-bolt-lightning"></i>
            </button>
            {{/each}}
        </div>
        {{/if}}

        <div class="combatant-buttons">
            {{#if isGM}}
            <i class="fas fa-eye-slash action" data-action="toggle-hidden" title="{{localize 'combat-tracker-dock.controls.toggleHidden'}}"></i>
            <i class="fas fa-skull action" data-action="toggle-defeated" title="{{localize 'combat-tracker-dock.controls.toggleDefeated'}}"></i>
            {{/if}}
            <i class="fas fa-bullseye-arrow action" data-action="ping" title="{{localize 'combat-tracker-dock.controls.ping'}}"></i>
        </div>

        {{#unless isDaggerheart}}
        <div class="tracked-attribute-text-container" {{#if isDaggerheart}}style="display: none;"{{else unless showText}}style="display: none;"{{/if}}>
            <i class="tracked-attribute-text-value">{{resource.value}}</i>
            {{#if resource.max}}
            <i>/</i>
            <i>{{resource.max}}</i>
            {{/if}}
        </div>

        <div class="tracked-attribute-text-container" {{#if isDaggerheart}}style="display: none;"{{else unless showText}}style="display: none;"{{/if}}>
            <i class="tracked-attribute-text-value secondary-attribute">{{resource2.value}}</i>
            {{#if resource2.max}}
            <i>/</i>
            <i>{{resource2.max}}</i>
            {{/if}}
        </div>

        {{#if resSystemIcons}}
        <div class="system-icons" style="gap: calc(var(--combatant-portrait-size)*{{systemIconsSizeMulti}});">
            {{#each resSystemIcons}}
            <i data-index="{{@index}}" data-id="{{id}}" class="system-icon {{icon}} {{#if hasCallback}}{{#if enabled}}callback{{/if}}{{/if}}" style="color: {{color}};{{#unless visible}}display: none;{{/unless}}{{#unless enabled}}filter: grayscale(1);{{/unless}}{{#if fontSize}}font-size: {{fontSize}};{{/if}}"></i>
            {{/each}}
        </div>
        {{/if}}
        {{/unless}}

    </div>
    {{#if hasPlayerOwner}}
    <div class="image-border"></div>
    {{/if}}
</div>
